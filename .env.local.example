# ============================================================
# Configuração de envio de e-mail do formulário de orçamento
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# As variáveis SMTP_* são OBRIGATÓRIAS para o envio funcionar.

# Destinatário final (recebe os pedidos de orçamento).
# Se omitir, o default é msol.leonardo@outlook.com
EMAIL_TO=msol.leonardo@outlook.com

# Remetente exibido no e-mail (opcional)
# Por padrão usa SMTP_USER.
SMTP_FROM="LM Energy — Site <msol.leonardo@outlook.com>"

# ------------------------------------------------------------
# SMTP do Outlook / Office 365 (recomendado para esta conta)
# ------------------------------------------------------------
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=msol.leonardo@outlook.com
# IMPORTANTE: gere uma "App Password" em https://account.microsoft.com/security
# (a senha normal da conta NÃO funciona com SMTP).
SMTP_PASS=sua-app-password-aqui

# ------------------------------------------------------------
# Alternativas: Gmail
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=sua-senha-de-app
